require("dotenv").config();
const app = require("../app");
const debug = require("debug")("server:server");
const http = require("http");
const jwt = require("jsonwebtoken");
const { Server } = require("socket.io");
const messageModel = require("../database/chatmodel.js");
const userModel = require("../database/usermodel.js");
const bannedIps = require("../database/bannedips.js");
const port = normalizePort(process.env.PORT || "8080");
app.set("port", port);
async function addColors(arr) {
  return await Promise.all(
    arr.map(async (item) => {
      const shavedEmail = item.email.replace(/💻|📱/g, "").trim();
      const colorInDb = await userModel.findOne({ email: shavedEmail });
      const user = colorInDb || 0;
      return { ...item.toObject(), color: user?.color || "lightgray", image: user?.image || "none", rank: user?.rank || "member" };
    })
  );
}
function escapeHtml(str) {
  if (typeof str !== "string") return str;
  return str
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");
}
const server = http.createServer(app);
const io = new Server(server, {
  cors: {
    origin: process.env.FRONTEND_URL,
    methods: ["GET", "POST"],
    credentials: true,
  },
});
function checkIfBanned(email) {
  return new Promise(async (resolve, reject) => {
    try {
      const user = await userModel.findOne({ email: email.replace(/💻|📱/g, "").trim() });
      if (!user) resolve({ error: "No user found" });
      const isIpBanned = await bannedIps.findOne({ ip: user?.ip });
      if (user?.banned || isIpBanned?.banned) {
        resolve({ banned: true, reason: user?.bannedReason || isIpBanned?.reason || "No reason given" });
      } else {
        resolve(false);
      }
    } catch (err) {
      reject(err);
    }
  });
}
const usersConnected = new Map();
function sendUsersConnectedToRoom() {
  const usersOnlineMap = new Map();
  for (let x of [...usersConnected.keys()]) {
    const id = [...usersConnected.get(x).roomId];
    for (let idd of id) {
      if (!usersOnlineMap.has(idd)) usersOnlineMap.set(idd, new Set());
      usersOnlineMap.get(idd).add(x);
    }
  }
  for (let [rmId, usrs] of usersOnlineMap.entries()) {
    io.to(rmId).emit("users connected", [...usrs]);
  }
}
io.on("connection", async (socket) => {
  function isBanned(email) {
    return checkIfBanned(email).then((banned) => {
      if (banned?.error) { socket.emit("error", banned); socket.disconnect(); return; }
      if (banned?.banned) { socket.emit("is banned", banned); socket.disconnect(); return; }
    }).catch(console.error);
  }
  let email;
  try {
    const handshake = socket.handshake;
    if (!handshake.auth) throw new Error("No authentication given.");
    const token = handshake.auth.auth || "";
    if (!token) { socket.disconnect(); return; }
    const decoded = jwt.verify(token, process.env.JWT);
    const deviceEmoji = handshake.device === "mobile" ? "📱" : "💻";
    socket.data.email = decoded.email + " " + deviceEmoji + " ";
    email = socket.data.email;
    if (!email) throw new Error("No email detected.");
    isBanned(email);
  } catch (err) {
    console.error("Error occurred. Error: ", err);
    socket.disconnect();
    return;
  }
  async function sendMessagesToRoom(roomId) {
    if (!roomId) return;
    const message = await messageModel.find({ roomId }).sort({ createdAt: 1 }).limit(100);
    const messages = await addColors(message);
    io.to(roomId).emit("chat message", messages);
  }
  async function joinRoomHandler(roomId) {
    roomId = String(roomId).toLowerCase();
    socket.join(roomId);
    const num = usersConnected.get(email)?.numOfConnected || 0;
    const set = usersConnected.get(email)?.roomId || new Set();
    usersConnected.set(email, { numOfConnected: num + 1, roomId: new Set([...set, roomId]) });
    socket.data.roomId = roomId;
    socket.emit("chat message", await addColors(await messageModel.find({ roomId: socket.data.roomId }).sort({ createdAt: 1 }).limit(100)));
    io.emit("users online", [...usersConnected.keys()].length);
    sendUsersConnectedToRoom();
  }
  async function chatMessageHandler(msg) {
    isBanned(socket.data.email);
    const roomId = socket.data.roomId;
    if (!roomId) return;
    const senderEmail = socket.data.email.replace(/💻|📱/g, "").trim();

    // ── /mute command (only druncx@gmail.com and admin@admin.com) ──
    const muteMatch = msg.match(/^\/mute\s+(\S+)\s+(\d+)(m|s|h)$/i);
    const allowedMuters = process.env.ADMINS;
    if (muteMatch) {
      if (!allowedMuters.includes(senderEmail)) return;
      const targetEmail = muteMatch[1];
      const amount = parseInt(muteMatch[2]);
      const unit = muteMatch[3].toLowerCase();
      const ms = unit === "m" ? amount * 60000 : unit === "h" ? amount * 3600000 : amount * 1000;
      const mutedUntil = new Date(Date.now() + ms);
      await userModel.findOneAndUpdate({ email: targetEmail }, { mutedUntil });
      console.log(`${targetEmail} muted for ${amount}${unit} by ${senderEmail}`);
      return;
    }

    // ── Mute check — block muted users from sending ──
    const senderUser = await userModel.findOne({ email: senderEmail });
    if (senderUser?.mutedUntil && new Date(senderUser.mutedUntil) > new Date()) {
      const secondsLeft = Math.ceil((new Date(senderUser.mutedUntil) - new Date()) / 1000);
      socket.emit("muted", { secondsLeft });
      return;
    }

    if ((!msg || msg.trim() === "" || msg.trim().length > 100) && !((/:bypass/i.test(msg) && msg.length < 5000) || msg.match(/image\((.*?)\)/i))) return;
    const newMessage = new messageModel({
      email,
      text: escapeHtml(msg.trim().replace(/:bypass/gi, "")) || " ",
      roomId: roomId || "main",
    });
    await newMessage.save();
    const amount = await messageModel.countDocuments({ roomId });
    if (amount > 70) {
      const toDelete = await messageModel.find({ roomId }).sort({ createdAt: 1 }).limit(amount - 70);
      await messageModel.deleteMany({ _id: { $in: toDelete.map((doc) => doc._id) } });
    }
    sendMessagesToRoom(roomId);
  }
  function requestUsersOnlineHandler() {
    const roomId = socket.data.roomId;
    if (!roomId) return;
    socket.emit("users connected", [...usersConnected.keys()].filter((item) => (usersConnected.get(item)?.roomId || new Set(["main"])).has(roomId)));
  }
  async function deleteMessageHandler(id) {
    const message = await messageModel.findById(id);
    if (!message) return;
    const shavedEmail = socket.data.email.replace(/💻|📱/g, "").trim();
    const shavedUserEmail = message.email.replace(/💻|📱/g, "").trim();
    if (shavedUserEmail !== shavedEmail && ![...JSON.parse(process.env.ADMINS)].includes(shavedEmail)) return;
    await message.deleteOne();
    sendMessagesToRoom(socket.data.roomId);
  }
  function disconnectHandler() {
    socketCleanUp(socket);
    const count = (usersConnected.get(email)?.numOfConnected || 0) - 1;
    if (count > 0) {
      usersConnected.set(email, { ...usersConnected.get(email), numOfConnected: count });
    } else {
      usersConnected.delete(email);
    }
    sendUsersConnectedToRoom();
    io.emit("users online", [...usersConnected.keys()].length);
  }
  function socketCleanUp(socket) {
    socket.off("join room", joinRoomHandler);
    socket.off("chat message", chatMessageHandler);
    socket.off("request users connected", requestUsersOnlineHandler);
    socket.off("delete message", deleteMessageHandler);
    socket.off("disconnect", disconnectHandler);
  }
  socket.on("join room", joinRoomHandler);
  socket.on("delete message", deleteMessageHandler);
  socket.on("chat message", chatMessageHandler);
  socket.on("request users connected", requestUsersOnlineHandler);
  socket.on("disconnect", disconnectHandler);
});
server.listen(port, () => { console.log("Server listening on " + port); });
server.on("error", onError);
server.on("listening", onListening);
function normalizePort(val) {
  const port = parseInt(val, 10);
  if (isNaN(port)) return val;
  if (port >= 0) return port;
  return false;
}
function onError(error) {
  if (error.syscall !== "listen") throw error;
  const bind = typeof port === "string" ? "Pipe " + port : "Port " + port;
  switch (error.code) {
    case "EACCES": console.error(bind + " requires elevated privileges"); process.exit(1); break;
    case "EADDRINUSE": console.error(bind + " is already in use"); process.exit(1); break;
    default: throw error;
  }
}
function onListening() {
  const addr = server.address();
  const bind = typeof addr === "string" ? "pipe " + addr : "port " + addr.port;
  debug("Listening on " + bind);
}
